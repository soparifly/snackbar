{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "incremental": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2019"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tsup.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}